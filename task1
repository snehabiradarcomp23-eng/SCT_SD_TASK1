#include <iostream>
#include <iomanip>
#include <limits>

using namespace std;

// Function prototypes
void displayMenu();
void convertTemperature();

double celsiusToFahrenheit(double c);
double celsiusToKelvin(double c);
double fahrenheitToCelsius(double f);
double fahrenheitToKelvin(double f);
double kelvinToCelsius(double k);
double kelvinToFahrenheit(double k);

int main() {
    int choice;

    do {
        displayMenu();
        cout << "Enter your choice (1-3): ";
        cin >> choice;

        if (cin.fail()) {
            cin.clear();
            cin.ignore(numeric_limits<streamsize>::max(), '\n');
            cout << "Invalid input! Please enter a number.\n";
            continue;
        }

        switch (choice) {
            case 1:
                convertTemperature();
                break;

            case 2:
                cout << "\nTemperature Scale Information:\n";
                cout << "Celsius (°C): Water freezes at 0°C\n";
                cout << "Fahrenheit (°F): Water freezes at 32°F\n";
                cout << "Kelvin (K): Absolute zero is 0 K\n";
                break;

            case 3:
                cout << "Exiting program...\n";
                break;

            default:
                cout << "Invalid choice! Try again.\n";
        }

    } while (choice != 3);

    return 0;
}

void displayMenu() {
    cout << "\n--- Temperature Converter Menu ---\n";
    cout << "1. Convert Temperature\n";
    cout << "2. Temperature Scale Info\n";
    cout << "3. Exit\n";
}

void convertTemperature() {
    int choice;
    double temp;

    cout << "\nTemperature Converter\n";
    cout << "1. Celsius → Fahrenheit & Kelvin\n";
    cout << "2. Fahrenheit → Celsius & Kelvin\n";
    cout << "3. Kelvin → Celsius & Fahrenheit\n";
    cout << "Enter choice (1-3): ";
    cin >> choice;

    if (cin.fail()) {
        cin.clear();
        cin.ignore(numeric_limits<streamsize>::max(), '\n');
        cout << "Invalid choice!\n";
        return;
    }

    cout << "Enter temperature: ";
    cin >> temp;

    if (cin.fail()) {
        cin.clear();
        cin.ignore(numeric_limits<streamsize>::max(), '\n');
        cout << "Invalid temperature!\n";
        return;
    }

    cout << fixed << setprecision(2);

    switch (choice) {
        case 1:
            cout << temp << " °C = " << celsiusToFahrenheit(temp) << " °F\n";
            cout << temp << " °C = " << celsiusToKelvin(temp) << " K\n";
            break;

        case 2:
            cout << temp << " °F = " << fahrenheitToCelsius(temp) << " °C\n";
            cout << temp << " °F = " << fahrenheitToKelvin(temp) << " K\n";
            break;

        case 3:
            if (temp < 0) {
                cout << "Error: Kelvin cannot be negative!\n";
                return;
            }
            cout << temp << " K = " << kelvinToCelsius(temp) << " °C\n";
            cout << temp << " K = " << kelvinToFahrenheit(temp) << " °F\n";
            break;

        default:
            cout << "Invalid option!\n";
    }
}

// Conversion functions
double celsiusToFahrenheit(double c) {
    return (c * 9.0 / 5.0) + 32;
}

double celsiusToKelvin(double c) {
    return c + 273.15;
}

double fahrenheitToCelsius(double f) {
    return (f - 32) * 5.0 / 9.0;
}

double fahrenheitToKelvin(double f) {
    return (f - 32) * 5.0 / 9.0 + 273.15;
}

double kelvinToCelsius(double k) {
    return k - 273.15;
}

double kelvinToFahrenheit(double k) {
    return (k - 273.15) * 9.0 / 5.0 + 32;
}
